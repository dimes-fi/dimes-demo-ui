    "@turnkey/viem": "^0.14.31",
    "permissionless": "^0.3.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vaul": "^1.1.2",
    "viem": "^2.55.2",
    "wagmi": "^2.19.5",
    "zustand": "^5.0.14"
