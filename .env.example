# ---------------------------------------------------------------------------
# Copy this file to .env.local and edit as needed. The defaults below run the
# demo against the Dimes sandbox (Polygon mainnet, mock USDC, demo wallet).
# cp .env.example .env.local && npm run dev should Just Work.
# ---------------------------------------------------------------------------

# Dimes API base URL. Defaults to the public sandbox.
VITE_API_URL=https://api-sandbox.dimes.fi

# Optional per-endpoint base URL overrides. Leave empty to route through
# VITE_API_URL like every other call. Set one only when that specific
# endpoint is hosted on a separate domain — these do NOT affect any other
# API calls.
#   VITE_RELAYER_URL — overrides POST /v1/prediction-markets/relayer-submissions
#                      (the deposit-wallet relayer endpoint).
#   VITE_TOKEN_URL   — overrides POST /v1/prediction-markets/tokens and
#                      /demo-token (auth token minting).
VITE_RELAYER_URL=
VITE_TOKEN_URL=

# EVM chain id. 137 = Polygon mainnet (sandbox also runs here),
# 80002 = Polygon Amoy testnet.
VITE_CHAIN_ID=137

# Optional custom RPC URL for the chain above. Leave empty to use the default
# public RPC bundled with wagmi. Set this if you want your own Alchemy /
# Infura / QuickNode endpoint for reliability.
VITE_RPC_URL=

# USDC contract address the vault accepts as collateral. Switch this when
# targeting another environment:
#   Sandbox   (Polygon mainnet):  0xD477EDbe627E94639d7E92119Ca62a461c6ce555  (mock USDC)
#   Prod      (Polygon mainnet):  0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174  (bridged USDC.e)
#   Testnet   (Polygon Amoy):     0x5fb7b0527851267c1ab138cac8dbcd224b411135  (mock USDC)
VITE_USDC_ADDRESS=0xD477EDbe627E94639d7E92119Ca62a461c6ce555

# WalletConnect Cloud project id. The repo ships a demo id that works out of
# the box; get your own free id at https://cloud.walletconnect.com if you
# fork this for production. WalletConnect project ids are public identifiers,
# not secrets.
VITE_WALLETCONNECT_PROJECT_ID=cfbb587cab5df64463c2e5de5cad1f1f

# Optional Privy app id. When set, the UI swaps its default RainbowKit wallet
# stack for Privy (embedded wallets + Privy login). Leave empty to use the
# RainbowKit stack. The on-chain create/close flow is identical either way —
# Privy provides a wagmi connector, so every contract call still runs through
# wagmi. Get an app id from the Privy dashboard (https://dashboard.privy.io).
# Privy app ids are public client identifiers, not secrets.
VITE_PRIVY_APP_ID=

# Optional Turnkey embedded-wallet config. BOTH must be set to make Turnkey
# selectable. It is never an auto-default (unlike Privy) — it mounts only when
# the user picks "Connect with Turnkey", which is always the last option. Turnkey ships
# no wagmi connector, so the UI bundles a custom one; the on-chain flow is still
# unchanged. Get these from the Turnkey dashboard (https://dashboard.turnkey.com):
#   VITE_TURNKEY_ORG_ID                — your parent organization ID
#   VITE_TURNKEY_AUTH_PROXY_CONFIG_ID  — the WalletKit / Auth Proxy config ID
#                                        (enable Auth Proxy + auth methods first)
# Both are public client identifiers, not secrets.
VITE_TURNKEY_ORG_ID=
VITE_TURNKEY_AUTH_PROXY_CONFIG_ID=
# Optional Turnkey API base URL override; defaults to https://api.turnkey.com
VITE_TURNKEY_API_BASE_URL=

# ---------------------------------------------------------------------------
# Optional partner API key for minting real JWTs directly from the browser
# via POST /v1/prediction-markets/tokens, scoped to the connected wallet.
#
# Leave empty to run in DEMO MODE: the UI calls POST /demo-token with the
# fixed demo wallet 0xCB93661f8120A082a59642455b776311e1726420. That wallet
# is the only one the demo-token endpoint accepts, so every read and write
# in demo mode is scoped to it regardless of which wallet the user connects.
# Users can still connect their own wallet to sign on-chain transactions.
#
# DO NOT SHIP A REAL API KEY IN A FRONTEND. In production, tokens must be
# minted by your backend with the API key kept server-side, and your frontend
# should receive the JWT from your backend. This field exists only so the
# demo can run end-to-end with a single command.
# ---------------------------------------------------------------------------
VITE_API_KEY=
